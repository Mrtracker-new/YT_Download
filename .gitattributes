# Normalize line endings — LF in repo, native on checkout
* text=auto eol=lf

# Windows scripts must stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries — never touch
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.woff2 binary

# Keep lockfiles out of language stats on GitHub
package-lock.json linguist-generated=true
src-tauri/Cargo.lock linguist-generated=true
